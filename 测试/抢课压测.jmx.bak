            <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="??????(???????)" enabled="true">
              <stringProp name="cacheKey">seckill-allowed-code-assertion</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">def httpCode = prev.getResponseCode()
if (httpCode != '200') {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage('unexpected HTTP status: ' + httpCode)
    return
}
def code = vars.get('seckill_code')
def allowedCodes = ['SUCCESS', 'SOLD_OUT', 'ALREADY_SELECTED', 'NOT_STARTED', 'ENDED']
if (!allowedCodes.contains(code)) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage('unexpected seckill code: ' + code + ', response=' + prev.getResponseDataAsString())
}
</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
